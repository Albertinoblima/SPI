# SQLFluff Configuration for PostgreSQL
# Formato INI (único suportado pelo SQLFluff)
# Dialeto: PostgreSQL | Compatível com SQLFluff >= 2.0.0

[sqlfluff]
dialect = postgres
templater = raw
max_line_length = 120
exclude_rules = LT05,RF02,RF04,RF05,RF06,AL01,AL02,AL03,AL04,AL05,AL06,AL07,AL08
large_file_skip_byte_limit = 0

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4
indent_before = select_clause

[sqlfluff:layout:type:comma]
spacing_before = touch
spacing_after = single

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
capitalisation_policy = upper
